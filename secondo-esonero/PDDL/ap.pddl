; ==============================================================
; ANIMATION SATELLITE v3 (Planimate) — assign / predefine layout
; --------------------------------------------------------------
; Da caricare su https://editor.planning.domains insieme a:
;
;     domain_v3_alternative.pddl
;     problem_*_v3.pddl          (qualsiasi istanza v3)
;
; --------------------------------------------------------------
; DIFFERENZE RISPETTO A ap.pddl (v3)
;
;   - Posizionamento oggetti via (assign ...) e
;     distribute_within_objects_vertical (come grid_AP.pddl),
;     non coordinate fisse (equal (?o x) (?d x)).
;   - Oggetti del cielo raggruppati con :type predefine e
;     wildcard (%star, %planet, %galaxy, ...).
;   - Visuale libera sentphotos per le foto inviate a Terra.
;
; --------------------------------------------------------------
; PREDICATI ANIMATI
;
;   (pointing ?p)   la direzione puntata diventa arancione
;   (visible ?o ?d) ?o distribuito verticalmente vicino a ?d
;   (stored ?q ?o)  ?o distribuito vicino allo slot qualita' ?q
;   (sent ?o)       ?o distribuito nell'area sentphotos
;
; --------------------------------------------------------------
; VISUAL CUSTOM
;
;   customSatellite, customEarth, sentphotos
;   hd / sd (predefine), rosa dei venti N..NW
; ==============================================================

(define (animation satellite-v3)


  ; ============================================================
  ; PREDICATI -> EFFETTI VISIVI
  ; ============================================================

  (:predicate pointing
    :parameters (?p)
    ; La casella della direzione puntata diventa arancione.
    :effect (
;      (equal (?p height) 100)
;      (equal (?p width) 100)
      (equal (?p color) orange)
    )
  )

  (:predicate visible
    :parameters (?o ?d)
    :effect (
      (assign (?o x y) (function distribute_within_objects_vertical (objects ?o ?d)(settings (spacebtw 20))))
;      (equal (?o x) (add (?d x) (?o x)))
;      (equal (?o y) (add (?d y) (?o y)))
;      (assign (?o x) (function distributex (objects ?o) (settings (spacebtwn 40))))
    )
  )

  (:predicate stored
    :parameters (?q ?o)
    :effect (
      (assign (?o x y) (function distribute_within_objects_vertical (objects ?o ?q)(settings (spacebtw 20))))
    )
  )

  (:predicate sent
    :parameters (?o)
    :custom sentphotos
    :effect (
      (assign (?o x y) (function distribute_within_objects_vertical (objects ?o sentphotos)(settings (spacebtw 20))))
    )
  )


  ; ============================================================
  ; DEFAULT
  ; ============================================================

  (:visual default
    :type default
    :properties (
      (showName FALSE)
      (x 10) (y 20)
      (color RANDOMCOLOR)
      (width 80) (height 80)
      (depth 1)
    )
  )


  ; ============================================================
  ; SATELLITE  (centro canvas)
  ; ============================================================

  (:visual satellite
    :type custom
    :objects customSatellite
    :properties (
      (prefabImage img-sat)
      (showName FALSE) (color white)
      (x 125) (y 125)
      (width 80) (height 80)
      (depth 1)
    )
  )


  ; ============================================================
  ; ROSA DEI VENTI - 8 caselle
  ; ============================================================

  (:visual N
    :type custom
    :objects N
    :properties (
      (prefabImage img-block)
      (showName TRUE) (color white)
      (x 150) (y 300) (width 40) (height 40)
      (depth 1)
    )
  )

  (:visual NE
    :type custom
    :objects NE
    :properties (
      (prefabImage img-block)
      (showName TRUE) (color white)
      (x 256) (y 256) (width 40) (height 40)
      (depth 1)
    )
  )

  (:visual E
    :type custom
    :objects E
    :properties (
      (prefabImage img-block)
      (showName TRUE) (color white)
      (x 300) (y 150) (width 40) (height 40)
      (depth 1)
    )
  )

  (:visual SE
    :type custom
    :objects SE
    :properties (
      (prefabImage img-block)
      (showName TRUE) (color white)
      (x 256) (y 44) (width 40) (height 40)
      (depth 1)
    )
  )

  (:visual S
    :type custom
    :objects S
    :properties (
      (prefabImage img-block)
      (showName TRUE) (color white)
      (x 150) (y 0) (width 40) (height 40)
      (depth 1)
    )
  )

  (:visual SW
    :type custom
    :objects SW
    :properties (
      (prefabImage img-block)
      (showName TRUE) (color white)
      (x 44) (y 44) (width 40) (height 40)
      (depth 1)
    )
  )

  (:visual W
    :type custom
    :objects W
    :properties (
      (prefabImage img-block)
      (showName TRUE) (color white)
      (x 0) (y 150) (width 40) (height 40)
      (depth 1)
    )
  )

  (:visual NW
    :type custom
    :objects NW
    :properties (
      (prefabImage img-block)
      (showName TRUE) (color white)
      (x 44) (y 256) (width 40) (height 40)
      (depth 1)
    )
  )


  ; ============================================================
  ; SLOT HD / SD + TERRA + FOTO INVIATE
  ; ============================================================

  (:visual hd
    :type predefine
    :objects hd
    :properties (
      (prefabImage img-sd)
      (showName TRUE) (color yellow)
      (x 400) (y 50)
      (width 100) (height 100)
      (depth 1)
    )
  )

  (:visual sd
    :type predefine
    :objects sd
    :properties (
      (prefabImage img-sd)
      (showName TRUE) (color red)
      (x 500) (y 50)
      (width 100) (height 100)
      (depth 1)
    )
  )

  (:visual earth
    :type custom
    :objects customEarth
    :properties (
      (prefabImage img-earth)
      (showName FALSE) (color white)
      (x 100) (y 400)
      (width 100) (height 100)
      (depth 0)
    )
  )

  (:visual sentphotos
    :type custom
    :objects sentphotos
    :properties (
      (prefabImage img-fold)
      (showName FALSE) (color white)
      (x 200) (y 400)
      (width 100) (height 100)
      (depth 0)
    )
  )


  ; ============================================================
  ; OGGETTI DEL CIELO  (:type predefine + wildcard)
  ; ============================================================

  (:visual stars
    :type predefine
    :objects (%star)
    :properties (
      (prefabImage img-star)
      (showName FALSE) (color white)
      (x Null) (y Null)
      (width 40) (height 40)
      (depth 2)
    )
  )

  (:visual galaxies
