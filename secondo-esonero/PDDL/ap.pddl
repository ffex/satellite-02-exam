  (:visual planets
    :type predefine
    :objects (%planet)
    :properties (
      (prefabImage img-plan)
      (showName FALSE) (color white)
      (x Null) (y Null)
      (width 40) (height 40)
      (depth 2)
    )
  )

  (:visual junk
    :type predefine
    :objects (%noise %junk %dust %asteroid)
    :properties (
      (prefabImage img-junk)
      (showName FALSE) (color white)
      (x Null) (y Null)
      (width 40) (height 40)
      (depth 2)
    )
  )


  ; ============================================================
  ; IMMAGINI (base64)
  ;
  ; Use https://www.base64encode.org/#encodefiles to encode.
  ; ============================================================

(:image
(img-sat )
(img-block )
(img-star )
(img-junk )
(img-earth )
(img-gal )
(img-plan )
   ; Use https://www.base64encode.org/#encodefiles to encode images in base64
(img-sd )
